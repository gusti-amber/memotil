  <!-- ヒーローセクション（大きなロゴ＋キャッチコピー＋CTAボタン） -->
  <section class="w-full px-10 pt-16 flex flex-col items-center justify-center gap-6">
    <h1 class="text-3xl md:text-4xl font-bold text-center">
      「あとでまとめよう」を、なくそう。
    </h1>
    <p class="text-base md:text-lg text-muted text-center max-w-2xl">
      めもTILは、エンジニアのための学習・作業メモアプリです。<br>
      学習・作業中の気づきをチャット感覚でメモして、GitHubにTILとして記録するまでをひとつの場所で完結できます。
    </p>
    <%= link_to "めもTILを始める", tasks_path, class: "btn btn-lg btn-primary rounded-full text-base" %>
  </section>

  <div class="divider px-30 pt-10"></div>

