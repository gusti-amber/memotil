<div class="flex justify-center">
  <div class="flex flex-col gap-6 p-12 max-w-2xl w-full text-base-content">
    <!-- エラーメッセージ表示エリア -->
    <%= render 'shared/error_messages', object: @task %>
    
    <%= form_with model: @task, local: true, html: { class: "flex flex-col gap-6 w-full" } do |f| %>
      <!-- タイトル入力フィールド -->
      <div class="w-full">
        <%= f.label :title, class: "text-sm font-semibold" %>
        <%= f.text_field :title,
                         class: "input input-neutral input-lg bg-surface border border-subtle text-base w-full placeholder:text-placeholder",
                         placeholder: "タイトルを入力してください...",
                         autocomplete: "off" %>
      </div>

      <!-- 概要 -->
      <div class="w-full">
        <%= f.label :description, class: "text-sm font-semibold" %>
        <%= f.text_area :description,
                        rows: 4,
                        class: "textarea bg-surface border border-subtle w-full min-h-24 text-base leading-relaxed placeholder:text-placeholder",
                        placeholder: "タスクの目標、テーマなどを説明してください..." %>
      </div>

      <%= render "tag_field", f: f, task: @task %>

      <!-- ボタンセクション -->
      <div class="flex justify-end gap-4 mt-6">
        <%= link_to "戻る", task_path(@task), class: "btn btn-ghost rounded-full shadow-none border-none hover:bg-neutral/10" %>
        <%= f.submit "変更", class: "btn btn-primary rounded-full shadow-none" %>
      </div>
    <% end %>
  </div>
</div>